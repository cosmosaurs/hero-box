<div class="cs-hero-box-image-import">
  <nav class="cs-hero-box-image-import__tabs">
    <button 
      type="button" 
      class="cs-hero-box-image-import__tab {{#if isSingleMode}}active{{/if}}"
      data-action="setMode"
      data-mode="single"
    >
      <i class="fas fa-image"></i>
      {{localize "cs-hero-box.imageImport.modeSingle"}}
    </button>
    <button 
      type="button" 
      class="cs-hero-box-image-import__tab {{#if isFolderMode}}active{{/if}}"
      data-action="setMode"
      data-mode="folder"
    >
      <i class="fas fa-folder-open"></i>
      {{localize "cs-hero-box.imageImport.modeFolder"}}
    </button>
  </nav>

  {{#if isSingleMode}}
    <div class="cs-hero-box-image-import__previews">
      <div class="cs-hero-box-preview cs-hero-box-preview--lg">
        <label class="cs-hero-box-preview__label">{{localize "cs-hero-box.imageImport.tokenPreview"}}</label>
        {{#if tokenUrl}}
          <img class="cs-hero-box-preview__image" src="{{tokenUrl}}" alt="Token" />
        {{else}}
          <div class="cs-hero-box-preview__placeholder">
            <i class="fas fa-user-circle"></i>
          </div>
        {{/if}}
      </div>
      <div class="cs-hero-box-preview cs-hero-box-preview--lg">
        <label class="cs-hero-box-preview__label">{{localize "cs-hero-box.imageImport.portraitPreview"}}</label>
        {{#if portraitUrl}}
          <img class="cs-hero-box-preview__image" src="{{portraitUrl}}" alt="Portrait" />
        {{else}}
          <div class="cs-hero-box-preview__placeholder">
            <i class="fas fa-portrait"></i>
          </div>
        {{/if}}
      </div>
    </div>

    <div class="form-group">
      <label>{{localize "cs-hero-box.imageImport.tokenUrl"}}</label>
      <div class="cs-hero-box-url-input">
        <input type="text" name="tokenUrl" value="{{tokenUrl}}" placeholder="{{localize 'cs-hero-box.imageImport.tokenPlaceholder'}}" />
        <button type="button" data-action="browseToken" data-tooltip="{{localize 'cs-hero-box.imageImport.browse'}}">
          <i class="fas fa-folder-open"></i>
        </button>
      </div>
      <p class="hint">{{localize "cs-hero-box.imageImport.tokenHint"}}</p>
    </div>

    <div class="form-group">
      <label>{{localize "cs-hero-box.imageImport.portraitUrl"}}</label>
      <div class="cs-hero-box-url-input">
        <input type="text" name="portraitUrl" value="{{portraitUrl}}" placeholder="{{localize 'cs-hero-box.imageImport.portraitPlaceholder'}}" />
        <button type="button" data-action="browsePortrait" data-tooltip="{{localize 'cs-hero-box.imageImport.browse'}}">
          <i class="fas fa-folder-open"></i>
        </button>
      </div>
      <p class="hint">{{localize "cs-hero-box.imageImport.portraitHint"}}</p>
    </div>
  {{/if}}

  {{#if isFolderMode}}
    <p class="cs-hero-box-notes">{{localize "cs-hero-box.imageImport.folderNotes"}}</p>

    <div class="form-group">
      <label>{{localize "cs-hero-box.imageImport.tokenFolder"}}</label>
      <div class="cs-hero-box-url-input">
        <input type="text" name="tokenFolder" value="{{tokenFolder}}" placeholder="{{localize 'cs-hero-box.imageImport.tokenFolderPlaceholder'}}" />
        <button type="button" data-action="browseTokenFolder" data-tooltip="{{localize 'cs-hero-box.imageImport.browse'}}">
          <i class="fas fa-folder-open"></i>
        </button>
      </div>
      <p class="hint">{{localize "cs-hero-box.imageImport.tokenFolderHint"}}</p>
    </div>

    <div class="form-group">
      <label>{{localize "cs-hero-box.imageImport.portraitFolder"}}</label>
      <div class="cs-hero-box-url-input">
        <input type="text" name="portraitFolder" value="{{portraitFolder}}" placeholder="{{localize 'cs-hero-box.imageImport.portraitFolderPlaceholder'}}" />
        <button type="button" data-action="browsePortraitFolder" data-tooltip="{{localize 'cs-hero-box.imageImport.browse'}}">
          <i class="fas fa-folder-open"></i>
        </button>
      </div>
      <p class="hint">{{localize "cs-hero-box.imageImport.portraitFolderHint"}}</p>
    </div>
  {{/if}}

  <fieldset class="cs-hero-box-image-import__settings">
    <legend>{{localize "cs-hero-box.editor.settings"}}</legend>
    <div class="cs-hero-box-image-import__settings-row">
      <div class="cs-hero-box-image-import__scale-group">
        <label>{{localize "cs-hero-box.editor.scale"}}</label>
        <input type="number" name="scale" value="{{scale}}" min="0.1" max="3" step="0.1" />
      </div>
      <label class="cs-hero-box-image-import__checkbox-inline">
        <input type="checkbox" name="dynamicRing" {{#if dynamicRing}}checked{{/if}} />
        {{localize "cs-hero-box.editor.dynamicRing"}}
      </label>
    </div>
  </fieldset>
</div>